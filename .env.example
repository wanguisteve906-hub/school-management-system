# Copy this file to .env in this same folder (school-management-system/.env):
#   Copy-Item .env.example .env
# Backend also reads optional backend/.env for overrides.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=elimu_password
POSTGRES_DB=elimu_hms

# --- Pick ONE DATABASE_URL ---
# Postgres on this machine (pgAdmin) — host is localhost, not "db":
DATABASE_URL=postgresql+psycopg2://postgres:elimu_password@localhost:5432/elimu_hms
#
# Docker Compose only (Postgres service name is "db" on the Docker network):
# DATABASE_URL=postgresql+psycopg2://elimu_user:elimu_password@db:5432/elimu_hms
#
# SQLite only (no Postgres):
# DATABASE_URL=sqlite:///./elimu.db

REDIS_URL=redis://localhost:6379/0
# Docker Compose Redis:
# REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change_this_to_a_strong_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Include both localhost and 127.0.0.1 — the browser treats them as different origins.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

PGADMIN_DEFAULT_EMAIL=admin@elimu.local
PGADMIN_DEFAULT_PASSWORD=admin123
